    }
];

// Flat list for backward compatibility or default view
export const FLAT_UNITS = UNIT_CATEGORIES.reduce((acc, category) => {
    return [...acc, ...category.units];
}, []).sort();

// Helper to get units by group ID
export const getUnitsByGroup = (groupId) => {
    const category = UNIT_CATEGORIES.find(c => c.id === groupId);
    return category ? category.units : FLAT_UNITS;
};

export const getUnitGroupName = (groupId) => {
    if (!groupId) return '-';
    const category = UNIT_CATEGORIES.find(c => c.id === groupId);
    return category ? category.name : groupId;
};

// Helper to get group hierarchy for Detail Select (if needed)
