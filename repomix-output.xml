    // Check if user has already accepted cookies
    const hasAcceptedCookies = localStorage.getItem('cookies_accepted');
    if (!hasAcceptedCookies) {
        // Add a small delay for better UX
        setTimeout(() => {
            showCookieConsent.value = true;
        }, 1000);
    }
});

const acceptCookies = () => {
