const getReferenceIcon = (t) => ({ 'sale': '🛒', 'topup': '💰', 'voucher': '🎫' }[t] || '📝');
const getReferenceText = (t) => ({ 'sale': 'Pembelian', 'topup': 'Top-up Manual', 'voucher': 'Voucher' }[t] || t);

const summary = computed(() => {
