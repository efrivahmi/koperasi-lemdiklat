                                            <option value="return_to_supplier">Retur ke Supplier (Pengurangan - Refund)</option>
                                            <option value="sale">Penjualan Manual/Langsung (Pengurangan - Profit)</option>
                                            <option value="other">Lainnya (Custom)</option>
                                        </select>
                                    </div>

