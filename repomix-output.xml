const formatCurrency = (v) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(v);
const getTypeColor = (t) => t === 'credit' ? 'text-emerald-300' : 'text-rose-300';
