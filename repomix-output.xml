        'damage': 'Kerusakan Barang',
        'expired': 'Barang Kadaluarsa',
        'return_to_supplier': 'Retur ke Supplier',
        'other': 'Lainnya'
    };
    return labels[purpose] || 'Tidak Diketahui';
};

import ThermalPrintLayout from '@/Components/ThermalPrintLayout.vue';

const printThermal = () => {
    window.print();
};
</script>

